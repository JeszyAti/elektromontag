---

---

<section class="hero" id="hero">
  <div class="container hero__inner">
    <div class="hero__content">
      <div class="hero__badge">
        <svg viewBox="0 0 20 20" width="16" height="16" fill="currentColor" aria-hidden="true">
          <path fill-rule="evenodd" d="M6.267 3.455a3.066 3.066 0 001.745-.723 3.066 3.066 0 013.976 0 3.066 3.066 0 001.745.723 3.066 3.066 0 012.812 2.812c.051.643.304 1.254.723 1.745a3.066 3.066 0 010 3.976 3.066 3.066 0 00-.723 1.745 3.066 3.066 0 01-2.812 2.812 3.066 3.066 0 00-1.745.723 3.066 3.066 0 01-3.976 0 3.066 3.066 0 00-1.745-.723 3.066 3.066 0 01-2.812-2.812 3.066 3.066 0 00-.723-1.745 3.066 3.066 0 010-3.976 3.066 3.066 0 00.723-1.745 3.066 3.066 0 012.812-2.812zm7.44 5.252a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
        </svg>
        Arany Vállalkozás Díj nyertes &middot; 1990 óta
      </div>

      <h1 class="hero__title">
        Autóvillamossági szerviz
        <span class="hero__title-accent">Budapesten</span>
      </h1>

      <p class="hero__description">
        Megbízható autóvillamossági javítás és diagnosztika a XX. kerületben.
        35 éve segítünk neked — gyorsan, pontosan, garanciával.
      </p>

      <div class="hero__actions">
        <a href="tel:+36306248584" class="btn btn--primary btn--large hero__phone">
          <svg viewBox="0 0 20 20" width="20" height="20" fill="currentColor" aria-hidden="true">
            <path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z"/>
          </svg>
          +36 30 624 8584
        </a>
        <a href="#szolgaltatasok" class="btn btn--outline btn--large">
          Szolgáltatásaink
        </a>
      </div>

      <div class="hero__info">
        <div class="hero__info-item">
          <svg viewBox="0 0 20 20" width="18" height="18" fill="currentColor" aria-hidden="true">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-12a1 1 0 10-2 0v4a1 1 0 00.293.707l2.828 2.829a1 1 0 101.415-1.415L11 9.586V6z" clip-rule="evenodd"/>
          </svg>
          <div>
            <strong>H–Cs:</strong> 8:00–17:00<br>
            <strong>P:</strong> 8:00–16:00
          </div>
        </div>
        <div class="hero__info-item">
          <svg viewBox="0 0 20 20" width="18" height="18" fill="currentColor" aria-hidden="true">
            <path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd"/>
          </svg>
          <div>
            1205 Budapest,<br>Mártonffy utca 46.
          </div>
        </div>
      </div>
    </div>

    <div class="hero__visual">
      <div class="hero__image-wrapper">
        <img
          src="/images/dashboard.jpg"
          alt="Autó műszerfal figyelmeztető lámpákkal — világít, mint a karácsonyfa"
          class="hero__image"
          width="560"
          height="400"
          loading="eager"
        />
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    padding-top: calc(var(--header-height) + var(--spacing-3xl));
    padding-bottom: var(--spacing-4xl);
    background: linear-gradient(160deg, var(--color-bg) 0%, var(--color-bg-alt) 40%, var(--color-bg) 100%);
    overflow: hidden;
  }

  .hero__inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--spacing-3xl);
    align-items: center;
  }

  .hero__badge {
    display: inline-flex;
    align-items: center;
    gap: var(--spacing-xs);
    padding: var(--spacing-xs) var(--spacing-md);
    background-color: var(--color-accent-bg);
    color: var(--color-accent);
    font-size: var(--font-size-sm);
    font-weight: 600;
    border-radius: 9999px;
    margin-bottom: var(--spacing-lg);
  }

  .hero__title {
    font-size: var(--font-size-5xl);
    font-weight: 800;
    line-height: 1.1;
    color: var(--color-primary);
    margin-bottom: var(--spacing-lg);
  }

  .hero__title-accent {
    display: block;
    color: var(--color-accent);
  }

  .hero__description {
    font-size: var(--font-size-lg);
    color: var(--color-text-light);
    margin-bottom: var(--spacing-2xl);
    max-width: 500px;
  }

  .hero__actions {
    display: flex;
    gap: var(--spacing-md);
    margin-bottom: var(--spacing-2xl);
    flex-wrap: wrap;
  }

  .hero__info {
    display: flex;
    gap: var(--spacing-2xl);
  }

  .hero__info-item {
    display: flex;
    gap: var(--spacing-sm);
    font-size: var(--font-size-sm);
    color: var(--color-text-light);
  }

  .hero__info-item svg {
    color: var(--color-accent);
    flex-shrink: 0;
    margin-top: 2px;
  }

  .hero__visual {
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .hero__image-wrapper {
    position: relative;
    width: 100%;
    max-width: 560px;
    aspect-ratio: 7 / 5;
    border-radius: var(--radius-xl);
    overflow: hidden;
    border: 2px solid var(--color-border);
    background-color: var(--color-bg-alt);
  }

  .hero__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }



  @media (max-width: 768px) {
    .hero {
      padding-top: calc(var(--header-height) + var(--spacing-2xl));
    }

    .hero__inner {
      grid-template-columns: 1fr;
      gap: var(--spacing-xl);
    }

    .hero__visual {
      display: none;
    }

    .hero__title {
      font-size: var(--font-size-4xl);
    }

    .hero__info {
      flex-direction: column;
      gap: var(--spacing-md);
    }

    .hero__actions {
      flex-direction: column;
    }

    .hero__actions .btn {
      text-align: center;
      justify-content: center;
    }
  }
</style>
