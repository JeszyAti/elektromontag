---
const currentYear = new Date().getFullYear();
---

<footer class="footer">
  <div class="container footer__inner">
    <div class="footer__brand">
      <svg class="footer__logo" viewBox="0 0 280 50" aria-hidden="true">
        <circle cx="25" cy="25" r="23" fill="#22262b" stroke="var(--color-accent)" stroke-width="2"/>
        <path d="M29 7L17 26h8l-2 17 14-20h-8l2-16z" fill="var(--color-accent)"/>
        <line x1="36" y1="12" x2="40" y2="9" stroke="var(--color-accent)" stroke-width="1.5" stroke-linecap="round" opacity="0.6"/>
        <line x1="38" y1="18" x2="43" y2="17" stroke="var(--color-accent)" stroke-width="1.5" stroke-linecap="round" opacity="0.4"/>
        <text x="56" y="20" font-family="Inter, system-ui, sans-serif" font-size="13" font-weight="800" fill="var(--color-text)" letter-spacing="1">ELEKTROMONTAG</text>
        <line x1="56" y1="27" x2="130" y2="27" stroke="var(--color-accent)" stroke-width="1.5"/>
        <text x="56" y="40" font-family="Inter, system-ui, sans-serif" font-size="8.5" font-weight="500" fill="var(--color-text-light)" letter-spacing="3.5">AUTÓVILLAMOSSÁGI SZERVIZ</text>
      </svg>
    </div>
    <p class="footer__copy">
      &copy; {currentYear} Elektromontag Autóvillamossági Szerviz. Minden jog fenntartva.
    </p>
  </div>
</footer>

<style>
  .footer {
    background-color: var(--color-bg-dark);
    padding: var(--spacing-xl) 0;
    border-top: 1px solid var(--color-border);
  }

  .footer__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: var(--spacing-md);
  }

  .footer__brand {
    display: flex;
    align-items: center;
  }

  .footer__logo {
    height: 36px;
    width: auto;
  }

  .footer__copy {
    font-size: var(--font-size-sm);
    color: var(--color-text-light);
  }

  @media (max-width: 768px) {
    .footer__inner {
      flex-direction: column;
      text-align: center;
    }
  }
</style>
