---
const expressServices = [
  { name: 'Izzó csere', detail: 'Halogén, Led és Xenon izzók', icon: 'bulb' },
  { name: 'Akkumulátor és generátor bevizsgálás', detail: 'Azonnali állapotfelmérés', icon: 'battery' },
  { name: 'Hibakódolvasás', detail: 'Fedélzeti diagnosztika', icon: 'code' },
  { name: 'Klímafeltöltés', detail: 'Régi és új típusú klímagázzal', icon: 'snow' },
];

const mainServices = [
  { name: 'Önindító javítás', desc: 'Indítómotor hibák diagnosztizálása és javítása' },
  { name: 'Generátor javítás', desc: 'Töltési rendszer hibák feltárása és javítása' },
  { name: 'Tolatóradar és tolatókamera', desc: 'Parkolássegítő rendszerek telepítése' },
  { name: 'Autóhifi', desc: 'Fejegység, hangszóró, erősítő beszerelés' },
  { name: 'Menetrögzítő kamera', desc: 'Dashcam telepítés és bekötés' },
  { name: 'Ablakemelő javítás', desc: 'Elektromos ablakemelő szerkezet javítása' },
  { name: 'Központi zár', desc: 'Központi zár rendszer javítás és beszerelés' },
  { name: 'Klímajavítás és feltöltés', desc: 'Autóklíma diagnosztika, javítás és feltöltés — régi és új típusú klímagázzal is dolgozunk' },
  { name: 'Szivárgás keresés', desc: 'Klíma- és elektromos rendszer szivárgás felderítése' },
  { name: 'Akkumulátor értékesítés', desc: 'Akku tesztelés, új akkumulátor értékesítés — régi aksik veszélyes hulladékként való átvétele' },
  { name: 'Hibakód olvasás', desc: 'Fedélzeti diagnosztika, hibakód kiolvasás és törlés' },
  { name: 'Általános hibakeresés', desc: 'Komplex elektromos hibák felderítése' },
  { name: 'Műszaki vizsgára felkészítés', desc: 'Világítás, jelzőfények, elektromos rendszer ellenőrzése' },
  { name: 'Ablaktörlő és ablakmosó javítás', desc: 'Ablaktörlő motor, mechanika és ablakmosó rendszer javítása' },
  { name: 'Fűtőmotor javítás', desc: 'Utastér fűtés/szellőzés motor javítása' },
  { name: 'Légzsák, ABS és biztonsági rendszerek', desc: 'Légzsák, ABS, duda és egyéb biztonsági rendszerek diagnosztikája és javítása' },
  { name: 'Nappali menetfény és ködlámpa', desc: 'Nappali menetfény (DRL) és ködlámpa beszerelés, javítás' },
  { name: 'Vonóhorog bekötés', desc: 'Utánfutó csatlakozó elektromos bekötése' },
];
---

<section class="section" id="szolgaltatasok">
  <div class="container">
    <div class="section__header reveal">
      <h2 class="section__title">Szolgáltatásaink</h2>
      <p class="section__subtitle">Személygépjárművek és kishaszongépjárművek — 3,5 tonnáig</p>
    </div>

    <!-- Express Services -->
    <div class="express reveal">
      <div class="express__header">
        <span class="express__badge">Soron kívül</span>
        <p class="express__text">Ezekre a szolgáltatásokra nem kell időpontot foglalnod — sorbanállás nélkül elvégezzük!</p>
      </div>
      <div class="express__grid">
        {expressServices.map(service => (
          <div class="express__card">
            <div class="express__icon" aria-hidden="true">
              {service.icon === 'bulb' && (
                <svg viewBox="0 0 24 24" width="28" height="28" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M9 21h6M12 3a6 6 0 00-4 10.5V17h8v-3.5A6 6 0 0012 3z"/>
                </svg>
              )}
              {service.icon === 'battery' && (
                <svg viewBox="0 0 24 24" width="28" height="28" fill="none" stroke="currentColor" stroke-width="2">
                  <rect x="1" y="6" width="18" height="12" rx="2"/><line x1="23" y1="10" x2="23" y2="14"/><line x1="7" y1="10" x2="7" y2="14"/><line x1="12" y1="10" x2="12" y2="14"/>
                </svg>
              )}
              {service.icon === 'code' && (
                <svg viewBox="0 0 24 24" width="28" height="28" fill="none" stroke="currentColor" stroke-width="2">
                  <rect x="2" y="3" width="20" height="18" rx="2"/><path d="M8 12l3 3-3 3M13 15h3"/>
                </svg>
              )}
              {service.icon === 'snow' && (
                <svg viewBox="0 0 24 24" width="28" height="28" fill="none" stroke="currentColor" stroke-width="2">
                  <line x1="12" y1="2" x2="12" y2="22"/><line x1="2" y1="12" x2="22" y2="12"/><line x1="4.93" y1="4.93" x2="19.07" y2="19.07"/><line x1="19.07" y1="4.93" x2="4.93" y2="19.07"/>
                </svg>
              )}
            </div>
            <div>
              <h3 class="express__name">{service.name}</h3>
              <p class="express__detail">{service.detail}</p>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- Main Services Grid -->
    <div class="services-grid reveal">
      {mainServices.map(service => (
        <div class="service-card">
          <div class="service-card__icon" aria-hidden="true">
            <svg viewBox="0 0 20 20" width="20" height="20" fill="currentColor">
              <path fill-rule="evenodd" d="M11.3 1.046A1 1 0 0112 2v5h4a1 1 0 01.82 1.573l-7 10A1 1 0 018 18v-5H4a1 1 0 01-.82-1.573l7-10a1 1 0 011.12-.38z" clip-rule="evenodd"/>
            </svg>
          </div>
          <h3 class="service-card__name">{service.name}</h3>
          <p class="service-card__desc">{service.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  /* Express Services */
  .express {
    background: linear-gradient(135deg, #2a2e33 0%, #33383e 100%);
    border-radius: var(--radius-xl);
    padding: var(--spacing-2xl);
    margin-bottom: var(--spacing-3xl);
  }

  .express__header {
    text-align: center;
    margin-bottom: var(--spacing-xl);
  }

  .express__badge {
    display: inline-block;
    background-color: var(--color-accent);
    color: var(--color-primary-dark);
    font-size: var(--font-size-sm);
    font-weight: 700;
    padding: var(--spacing-xs) var(--spacing-md);
    border-radius: 9999px;
    margin-bottom: var(--spacing-sm);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .express__text {
    color: rgba(255, 255, 255, 0.85);
    font-size: var(--font-size-base);
  }

  .express__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: var(--spacing-md);
  }

  .express__card {
    display: flex;
    align-items: center;
    gap: var(--spacing-md);
    background-color: rgba(255, 255, 255, 0.1);
    border: 1px solid rgba(255, 255, 255, 0.15);
    border-radius: var(--radius-lg);
    padding: var(--spacing-lg);
    transition: background-color 0.2s;
  }

  .express__card:hover {
    background-color: rgba(255, 255, 255, 0.15);
  }

  .express__icon {
    color: var(--color-accent);
    flex-shrink: 0;
  }

  .express__name {
    color: #fff;
    font-size: var(--font-size-base);
    font-weight: 600;
  }

  .express__detail {
    color: rgba(255, 255, 255, 0.7);
    font-size: var(--font-size-sm);
  }

  /* Main Services Grid */
  .services-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
    gap: var(--spacing-lg);
  }

  .service-card {
    padding: var(--spacing-xl);
    background-color: var(--color-bg-alt);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    transition: all 0.3s;
  }

  .service-card:hover {
    border-color: var(--color-accent);
    box-shadow: 0 0 20px rgba(245, 158, 11, 0.1);
    transform: translateY(-3px);
  }

  .service-card__icon {
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: var(--color-accent-bg);
    color: var(--color-accent);
    border-radius: var(--radius-md);
    margin-bottom: var(--spacing-md);
  }

  .service-card__name {
    font-size: var(--font-size-base);
    font-weight: 600;
    color: var(--color-accent);
    margin-bottom: var(--spacing-xs);
  }

  .service-card__desc {
    font-size: var(--font-size-sm);
    color: var(--color-text-light);
    line-height: 1.5;
  }

  @media (max-width: 768px) {
    .express {
      padding: var(--spacing-md);
    }

    .express__grid {
      grid-template-columns: 1fr;
    }

    .services-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
